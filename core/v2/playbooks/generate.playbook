{
  "name": "doc_generate",
  "description": "Generate a document from a template and data.",
  "vars": ["template_path", "output_path", "title"],
  "steps": [
    {"action": "read_file", "path": "{{template_path}}"},
    {"action": "write_file", "path": "{{output_path}}", "content": "# {{title}}\n\nGenerated from template."},
    {"action": "complete"}
  ]
}
